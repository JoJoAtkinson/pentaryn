# Local secrets
.env

# Combat-runner per-encounter auto-memory (per-machine state)
combat-runner/.memory/

# Combat-runner scenario-test metrics (per-run output, machine-local)
combat-runner/tests/.metrics/

# Combat-runner testbot per-run output (run JSONs, cron logs, decisions, etc.)
# scenarios.yml is a hand-authored config input — keep it tracked.
# Ignore dir *contents* (not the dir itself) so the negation can re-include the file.
combat-runner/.testbot/*
!combat-runner/.testbot/scenarios.yml
!combat-runner/.testbot/*-cron-prompt.md
!combat-runner/.testbot/playtest-*.md
